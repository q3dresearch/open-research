# ── Runtime data — never committed ──────────────────────────────────────────
# Downloaded datasets
data/

# Generated pipeline outputs (charts, tables, pipelines, notebooks)
artifacts/

# SQLite database — runtime state, differs per user.
# Initialize fresh: python scripts/init_db.py
observatory.db

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.local

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Docs build output ─────────────────────────────────────────────────────────
site/

# ── Memory — per-dataset journals are local/runtime ───────────────────────────
# memory/main/ is committed (identity files: SOUL.md, AGENTS.md, TOOLS.md)
memory/*
!memory/main
!memory/main/**
